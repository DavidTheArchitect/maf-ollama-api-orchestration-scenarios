# Optional. Leave unset to use the Copilot SDK default model.
GITHUB_COPILOT_MODEL=

# sequential-release-readiness, concurrent-pr-review, handoff-support-triage,
# group-chat-launch-council, or magentic-incident-response
RESPONSE_SCENARIO=sequential-release-readiness

# Local host port. Foundry-hosted agents usually inject PORT.
PORT=8088

# Learning sample default: keep Copilot from using command/file tools unless you intentionally enable them.
ALLOW_COPILOT_TOOLS=false
